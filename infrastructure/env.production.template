# EthicalSiteInspector Production Environment Configuration
# Copy this file to .env and fill in your actual values
# DO NOT commit .env files with real secrets to version control

# =============================================================================
# Application Settings
# =============================================================================

# Application environment (production, staging, development)
APP_ENV=production

# Application name
APP_NAME=EthicalSiteInspector API

# API prefix (should be /api for standard deployment)
API_PREFIX=/api

# =============================================================================
# Audit Mode Configuration
# =============================================================================

# Audit execution mode: mock, hybrid, live, or auto
# - mock: Simulated audits (fastest, no real browser)
# - hybrid: Real browser with mock AI classification
# - live: Real browser with Nova AI classification (requires AWS credentials)
# - auto: Automatically select based on available resources
AUDIT_MODE=auto

# Enable real browser for hybrid/live modes (requires Playwright)
USE_REAL_BROWSER=true

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================

# PostgreSQL connection URL
# Replace placeholders below with actual values from your RDS instance
DATABASE_URL=REPLACE_WITH_YOUR_POSTGRESQL_CONNECTION_STRING

# =============================================================================
# Storage Configuration
# =============================================================================

# Local storage root path (for SQLite mode or local file storage)
LOCAL_STORAGE_ROOT=/opt/ethicalsiteinspector/data

# Screenshot storage directory
SCREENSHOTS_DIR=/opt/ethicalsiteinspector/data/screenshots

# Report generation directory
REPORTS_DIR=/opt/ethicalsiteinspector/data/reports

# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed origins for CORS (comma-separated)
# In production, set this to your actual domain(s)
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# =============================================================================
# AWS Configuration (Required for S3 storage and Nova AI)
# =============================================================================

# AWS Region
AWS_REGION=us-east-1

# AWS Access Key ID (leave empty if using IAM instance profile)
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID

# AWS Secret Access Key (leave empty if using IAM instance profile)
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# AWS Session Token (for temporary credentials, usually empty in production)
AWS_SESSION_TOKEN=

# =============================================================================
# Nova AI Configuration
# =============================================================================

# Nova model ID for live audit mode
NOVA_MODEL_ID=us.amazon.nova-pro-v1:0

# =============================================================================
# S3 Storage Configuration (Required for video/artifact storage)
# =============================================================================

# S3 bucket name for storing artifacts and videos
S3_BUCKET_NAME=your-app-artifacts-bucket

# S3 endpoint URL (leave empty for standard AWS S3)
# For S3-compatible services like MinIO, set this to your endpoint
S3_ENDPOINT_URL=

# Public base URL for S3 objects (for generating public-facing URLs)
# This should match your CloudFront distribution or S3 website endpoint
S3_PUBLIC_BASE_URL=https://your-bucket.s3.amazonaws.com

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# Security Settings
# =============================================================================

# Secret key for session management and encryption
# Generate a secure random key (e.g., openssl rand -hex 32)
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET

# =============================================================================
# Rate Limiting (Optional)
# =============================================================================

# Rate limit requests per minute (0 to disable)
RATE_LIMIT_PER_MINUTE=60
