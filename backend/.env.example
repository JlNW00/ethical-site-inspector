APP_NAME=EthicalSiteInspector API
APP_ENV=development
API_PREFIX=/api
AUDIT_MODE=auto
USE_REAL_BROWSER=false
DATABASE_URL=sqlite:///C:/EthicalSiteInspector/data/ethicalsiteinspector.db
LOCAL_STORAGE_ROOT=C:/EthicalSiteInspector/data
SCREENSHOTS_DIR=C:/EthicalSiteInspector/data/screenshots
REPORTS_DIR=C:/EthicalSiteInspector/data/reports
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AWS_REGION=us-east-1
NOVA_MODEL_ID=us.amazon.nova-pro-v1:0
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
S3_BUCKET_NAME=
S3_ENDPOINT_URL=
S3_PUBLIC_BASE_URL=
