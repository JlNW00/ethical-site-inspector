  "components": {
    "schemas": {
      "AuditCreateRequest": {
        "properties": {
          "target_url": {
            "type": "string",
            "maxLength": 2083,
            "minLength": 1,
            "format": "uri",
            "title": "Target Url"
          },
          "scenarios": {
            "items": {
              "type": "string",
              "enum": [
                "cookie_consent",
                "checkout_flow",
                "cancellation_flow"
              ]
            },
            "type": "array",
            "title": "Scenarios"
          },
          "personas": {
            "items": {
              "type": "string",
              "enum": [
                "privacy_sensitive",
                "cost_sensitive",
                "exit_intent"
              ]
            },
            "type": "array",
            "title": "Personas"
          }
        },
        "type": "object",
        "required": [
          "target_url"
        ],
        "title": "AuditCreateRequest"
      },
      "AuditEventRead": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "phase": {
            "type": "string",
            "title": "Phase"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "progress": {
            "type": "integer",
            "title": "Progress"
          },
          "details": {
            "additionalProperties": true,
            "type": "object",
            "title": "Details"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "phase",
          "status",
          "message",
          "progress",
          "details",
          "created_at"
        ],
        "title": "AuditEventRead"
      },
      "AuditRead": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "target_url": {
            "type": "string",
            "title": "Target Url"
          },
          "mode": {
            "type": "string",
            "title": "Mode"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "summary": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Summary"
          },
          "trust_score": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Trust Score"
          },
          "risk_level": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Risk Level"
          },
          "selected_scenarios": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Selected Scenarios"
          },
          "selected_personas": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Selected Personas"
          },
          "report_public_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Report Public Url"
          },
          "metrics": {
            "additionalProperties": true,
            "type": "object",
            "title": "Metrics"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "started_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Started At"
          },
          "completed_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Completed At"
          },
          "events": {
            "items": {
              "$ref": "#/components/schemas/AuditEventRead"
            },
            "type": "array",
            "title": "Events",
            "default": []
          }
        },
        "type": "object",
        "required": [
          "id",
          "target_url",
          "mode",
          "status",
          "summary",
          "trust_score",
          "risk_level",
          "selected_scenarios",
          "selected_personas",
          "report_public_url",
          "metrics",
          "created_at",
          "updated_at",
          "started_at",
          "completed_at"
        ],
        "title": "AuditRead"
      },
      "FindingRead": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "scenario": {
            "type": "string",
            "title": "Scenario"
          },
          "persona": {
            "type": "string",
            "title": "Persona"
          },
          "pattern_family": {
            "type": "string",
            "title": "Pattern Family"
          },
          "severity": {
            "type": "string",
            "title": "Severity"
          },
          "title": {
            "type": "string",
            "title": "Title"
          },
          "explanation": {
            "type": "string",
            "title": "Explanation"
          },
          "remediation": {
            "type": "string",
            "title": "Remediation"
          },
          "evidence_excerpt": {
            "type": "string",
            "title": "Evidence Excerpt"
          },
          "rule_reason": {
            "type": "string",
            "title": "Rule Reason"
          },
          "evidence_payload": {
            "additionalProperties": true,
            "type": "object",
            "title": "Evidence Payload"
          },
          "confidence": {
            "type": "number",
            "title": "Confidence"
          },
          "trust_impact": {
            "type": "number",
            "title": "Trust Impact"
          },
          "order_index": {
            "type": "integer",
            "title": "Order Index"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "scenario",
          "persona",
          "pattern_family",
          "severity",
          "title",
          "explanation",
          "remediation",
          "evidence_excerpt",
          "rule_reason",
          "evidence_payload",
          "confidence",
          "trust_impact",
          "order_index",
          "created_at"
        ],
        "title": "FindingRead"
      },
      "FindingsResponse": {
        "properties": {
          "audit_id": {
            "type": "string",
            "title": "Audit Id"
          },
          "findings": {
            "items": {
              "$ref": "#/components/schemas/FindingRead"
            },
